dotenv_if_exists .env

unset PYENV_VERSION

remove_pyenv_shims() {
  local old_ifs="$IFS"
  local entry
  local next_path=""

  IFS=:
  for entry in $PATH; do
    case "$entry" in
      *pyenv*/shims) continue ;;
    esac

    if [ -z "$next_path" ]; then
      next_path="$entry"
    else
      next_path="$next_path:$entry"
    fi
  done
  IFS="$old_ifs"

  export PATH="$next_path"
}

remove_pyenv_shims
